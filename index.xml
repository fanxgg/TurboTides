;            hyphens: auto; /* 自动添加连字符 */&#xD;&#xA;            text-align: justify; /* 让文本两端对齐 */&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;        ul { &#xD;&#xA;            list-style-type: disc; &#xD;&#xA;            margin-left: 20px; &#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;        .turbo-image-container {&#xD;&#xA;            display: block;&#xD;&#xA;            width: 80%; /* 容器宽度 */&#xD;&#xA;            max-width: 1000px; /* 限制最大宽度 */&#xD;&#xA;            margin: 0 auto; /* 居中 */&#xD;&#xA;            text-align: center;&#xD;&#xA;        }&#xD;&#xA;        .turbo-image-container img {&#xD;&#xA;            display: block; /* 让图片变成块级元素 */&#xD;&#xA;            margin: 0 auto; /* 让图片水平居中 */&#xD;&#xA;            max-width: 100%; /* 确保不会超出父容器 */&#xD;&#xA;            height: auto;&#xD;&#xA;        }&#xD;&#xA;        .responsive-img {&#xD;&#xA;            width: 100%; /* 图片宽度为容器的100% */&#xD;&#xA;            height: auto; /* 保持图片的纵横比 */&#xD;&#xA;            display: block; /* 让图片作为块级元素 */&#xD;&#xA;            margin: 0 auto; /* 居中 */&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;        /* 新的样式，只针对四张图片的容器 */&#xD;&#xA;        .turbo-images-row {&#xD;&#xA;            display: flex; /* 使用 flexbox 来水平排列图片 */&#xD;&#xA;            justify-content: space-between; /* 图片之间的间隔均等分配 */&#xD;&#xA;            width: 100%; /* 容器占满宽度 */&#xD;&#xA;            max-width: 1000px; /* 限制最大宽度 */&#xD;&#xA;            margin: 0 auto; /* 居中 */&#xD;&#xA;        }&#xD;&#xA;        .turbo-images-row img {&#xD;&#xA;            width: 20%; /* 设置每张图片的宽度为容器的 22% */&#xD;&#xA;            height: auto; /* 确保图片比例不变 */&#xD;&#xA;            margin-top: 0; &#xD;&#xA;            margin-bottom: 0; &#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;        /* 新增√符号的列表样式 */&#xD;&#xA;        .checklist {&#xD;&#xA;            list-style-type: none; /* 不使用默认的项目符号 */&#xD;&#xA;            padding-left: 0;&#xD;&#xA;        }&#xD;&#xA;        .checklist li {&#xD;&#xA;            display: flex; /* 确保符号和文字对齐 */&#xD;&#xA;        }&#xD;&#xA;        .checklist li::before {&#xD;&#xA;            content: &#39;✓&#39;;&#xD;&#xA;            color: rgb(76, 83, 85); /* 勾选符号的颜色 */&#xD;&#xA;            margin-right: 20px; /* 符号与文本之间的间距 */&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;        .code-block { background-color: #f8f9fa; padding: 10px; border-radius: 5px; }&#xD;&#xA;    &lt;/style&gt;&#xD;&#xA;&lt;/head&gt;&#xD;&#xA;&lt;body class=&#34;turbo-page&#34;&gt;&#xD;&#xA;    &lt;div class=&#34;header-container&#34;&gt;&#xD;&#xA;        &lt;h1 class=&#34;turbo-H1&#34;&gt;TurboTides&lt;/h1&gt;&#xD;&#xA;        &lt;a href=&#34;https://fanxgg.github.io/TurboTides/docs/TurboTides.docx&#34; class=&#34;download-button&#34; download&gt;&#xD;&#xA;            &lt;i class=&#34;fa fa-download&#34;&gt;&lt;/i&gt;Download PDF&#xD;&#xA;        &lt;/a&gt;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;    &lt;h2 class=&#34;turbo-H2&#34;&gt;Turbomachinery Integrated Design System&lt;/h2&gt;&#xD;&#xA;    &lt;p&gt;TurboTides is a specialized tool tailored specifically for turbomachinery design, based on systems engineering principles, &#xD;&#xA;        offering turbomachinery industry users an integrated, intelligent, and customizable CAE design solution.&#xD;&#xA;    &lt;/p&gt;</description>
